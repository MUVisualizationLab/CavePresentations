# This project contains both the Unity project and the Python server, so there's a lot to ignore
#

#Project specific files
/OldNotes/
*.pptx

##UNITY 
.utmp/
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
